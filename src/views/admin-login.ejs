<%- include('header', { title: 'Admin Login', streamer: null }) %>

<div style="max-width: 400px; margin: 80px auto; text-align: center;">
  <h2 style="margin-bottom: 20px;">Admin Portal</h2>

  <% if (error === 'invalid') { %>
    <div class="alert" style="background: #e74c3c33; border: 1px solid #e74c3c;">Wrong password.</div>
  <% } %>
  <% if (error === 'not_configured') { %>
    <div class="alert" style="background: #e74c3c33; border: 1px solid #e74c3c;">ADMIN_PASSWORD env var not set.</div>
  <% } %>

  <form method="POST" action="/admin/login">
    <div class="form-group">
      <input type="password" name="password" placeholder="Admin password" autofocus style="text-align: center;">
    </div>
    <button type="submit" class="btn btn-primary" style="width: 100%;">Login</button>
  </form>
</div>

<%- include('footer') %>
