<%- include('header', { title: 'My Subscription', streamer: streamer }) %>

<a href="/dashboard" style="color: var(--text-secondary); font-size: 13px; font-family: var(--font-display); font-weight: 500; display: inline-flex; align-items: center; gap: 6px;">
  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
  Back to Dashboard
</a>
<h2 style="margin: 16px 0 24px; font-size: 24px; font-weight: 700;" class="animate-in">My Subscription</h2>

<% if (msg === 'activated') { %>
  <div class="alert alert-success">Subscription activated! Enjoy your new features.</div>
<% } %>
<% if (msg === 'cancelled') { %>
  <div class="alert alert-info">Your subscription has been cancelled. You're now on the Free plan.</div>
<% } %>

<div class="card animate-in animate-in-delay-1">
  <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px;">
    <div>
      <div style="display: flex; align-items: center; gap: 10px; margin-bottom: 6px;">
        <h3 style="margin: 0; font-size: 18px;"><%= tierConfig.name %> Plan</h3>
        <span class="badge badge-tier"><%= (subscription?.tier || 'free').toUpperCase() %></span>
      </div>
      <p style="color: var(--text-secondary); font-size: 14px;">
        <% if (subscription?.tier === 'free' || !subscription) { %>
          Free forever
        <% } else { %>
          <%= subscription.status === 'active' ? 'Active' : subscription.status %> &middot;
          <% if (subscription.expires_at) { %>Expires: <%= subscription.expires_at.split('T')[0] %><% } %>
        <% } %>
      </p>
    </div>
  </div>

  <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 24px; margin-bottom: 8px;">
    <div>
      <h4 style="font-size: 12px; color: var(--text-muted); margin-bottom: 12px; text-transform: uppercase; letter-spacing: 1px; font-family: var(--font-display); font-weight: 600;">Limits</h4>
      <ul style="list-style: none; padding: 0; font-size: 14px; color: var(--text-secondary); line-height: 2.2;">
        <li><%- '&#128421;' %> <%= tierConfig.maxGuilds === -1 ? 'Unlimited' : tierConfig.maxGuilds %> Discord server<%= tierConfig.maxGuilds !== 1 ? 's' : '' %></li>
        <li><%- '&#128266;' %> <%= tierConfig.maxTwitchChannels === -1 ? 'Unlimited' : tierConfig.maxTwitchChannels %> Twitch channel<%= tierConfig.maxTwitchChannels !== 1 ? 's' : '' %></li>
        <li><%- '&#127909;' %> <%= tierConfig.maxYoutubeChannels === -1 ? 'Unlimited' : tierConfig.maxYoutubeChannels %> YouTube channel<%= tierConfig.maxYoutubeChannels !== 1 ? 's' : '' %></li>
        <% if (tierConfig.delayMinutes > 0) { %>
          <li><%- '&#9203;' %> <%= tierConfig.delayMinutes %> min notification delay</li>
        <% } else { %>
          <li><%- '&#9889;' %> Instant notifications</li>
        <% } %>
      </ul>
    </div>
    <div>
      <h4 style="font-size: 12px; color: var(--text-muted); margin-bottom: 12px; text-transform: uppercase; letter-spacing: 1px; font-family: var(--font-display); font-weight: 600;">Features</h4>
      <ul style="list-style: none; padding: 0; font-size: 14px; color: var(--text-secondary); line-height: 2.2;">
        <li style="color: <%= tierConfig.twitchLive ? 'var(--text-primary)' : 'var(--text-muted)' %>;"><%- tierConfig.twitchLive ? '&#10003;' : '&#10007;' %> Twitch Live</li>
        <li style="color: <%= tierConfig.twitchClips ? 'var(--text-primary)' : 'var(--text-muted)' %>;"><%- tierConfig.twitchClips ? '&#10003;' : '&#10007;' %> Clip Notifications</li>
        <li style="color: <%= tierConfig.youtube ? 'var(--text-primary)' : 'var(--text-muted)' %>;"><%- tierConfig.youtube ? '&#10003;' : '&#10007;' %> YouTube</li>
        <li style="color: <%= tierConfig.welcome ? 'var(--text-primary)' : 'var(--text-muted)' %>;"><%- tierConfig.welcome ? '&#10003;' : '&#10007;' %> Welcome Messages</li>
        <li style="color: <%= tierConfig.subSync ? 'var(--text-primary)' : 'var(--text-muted)' %>;"><%- tierConfig.subSync ? '&#10003;' : '&#10007;' %> Sub Sync</li>
        <li style="color: <%= tierConfig.streamSummaries ? 'var(--text-primary)' : 'var(--text-muted)' %>;"><%- tierConfig.streamSummaries ? '&#10003;' : '&#10007;' %> Stream Summaries</li>
        <li style="color: <%= tierConfig.goLiveThreads ? 'var(--text-primary)' : 'var(--text-muted)' %>;"><%- tierConfig.goLiveThreads ? '&#10003;' : '&#10007;' %> Go-Live Threads</li>
        <li style="color: <%= tierConfig.webhooks ? 'var(--text-primary)' : 'var(--text-muted)' %>;"><%- tierConfig.webhooks ? '&#10003;' : '&#10007;' %> Webhooks</li>
      </ul>
    </div>
  </div>
</div>

<div style="display: flex; gap: 12px; margin-top: 8px;" class="animate-in animate-in-delay-2">
  <% if (!subscription || subscription.tier === 'free') { %>
    <a href="/pricing" class="btn btn-primary">Upgrade Plan</a>
  <% } else { %>
    <a href="/pricing" class="btn btn-primary">Change Plan</a>
    <form method="POST" action="/payment/subscription/cancel" onsubmit="return confirm('Are you sure you want to cancel? You will lose your current features and switch to the Free plan.')">
      <button type="submit" class="btn btn-danger">Cancel Subscription</button>
    </form>
  <% } %>
</div>

<%- include('footer') %>
