<%- include('header', { title: 'Manage Streamers', streamer: null }) %>

<div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px;">
  <h2>Manage Streamers</h2>
  <div>
    <a href="/admin/dashboard" class="btn btn-secondary">Dashboard</a>
    <a href="/admin/logout" class="btn btn-secondary" style="margin-left: 8px;">Logout</a>
  </div>
</div>

<% if (streamers.length === 0) { %>
  <p style="color: #adadb8;">No streamers registered yet.</p>
<% } else { %>
  <div class="card" style="overflow-x: auto;">
    <table style="width: 100%; border-collapse: collapse; font-size: 13px;">
      <thead>
        <tr style="border-bottom: 1px solid #303032; text-align: left;">
          <th style="padding: 8px; color: #adadb8;">Discord</th>
          <th style="padding: 8px; color: #adadb8;">Twitch</th>
          <th style="padding: 8px; color: #adadb8;">Servers</th>
          <th style="padding: 8px; color: #adadb8;">Notif. Today</th>
          <th style="padding: 8px; color: #adadb8;">Total Notif.</th>
          <th style="padding: 8px; color: #adadb8;">Status</th>
          <th style="padding: 8px; color: #adadb8;">Actions</th>
        </tr>
      </thead>
      <tbody>
        <% for (const s of streamers) { %>
          <tr style="border-bottom: 1px solid #1a1a1d;">
            <td style="padding: 8px;"><%= s.discord_display_name || s.discord_username %></td>
            <td style="padding: 8px;"><%= s.twitch_username || '—' %></td>
            <td style="padding: 8px; text-align: center;"><%= s.guild_count %></td>
            <td style="padding: 8px; text-align: center;"><%= s.notifications_today %></td>
            <td style="padding: 8px; text-align: center;"><%= s.total_notifications %></td>
            <td style="padding: 8px;">
              <% if (s.enabled) { %>
                <span style="color: #00b894;">Active</span>
              <% } else { %>
                <span style="color: #e74c3c;">Disabled</span>
                <% if (s.admin_note) { %>
                  <br><span style="color: #666; font-size: 11px;"><%= s.admin_note %></span>
                <% } %>
              <% } %>
            </td>
            <td style="padding: 8px;">
              <div style="display: flex; gap: 6px;">
                <form method="POST" action="/admin/streamers/<%= s.id %>/toggle" style="margin: 0;">
                  <% if (s.enabled) { %>
                    <input type="hidden" name="note" value="Disabled by admin">
                    <button type="submit" class="btn btn-secondary" style="padding: 4px 10px; font-size: 12px;">Disable</button>
                  <% } else { %>
                    <button type="submit" class="btn btn-success" style="padding: 4px 10px; font-size: 12px;">Enable</button>
                  <% } %>
                </form>
                <form method="POST" action="/admin/streamers/<%= s.id %>/remove" style="margin: 0;" onsubmit="return confirm('Remove this streamer and all their data?')">
                  <button type="submit" class="btn btn-danger" style="padding: 4px 10px; font-size: 12px;">Remove</button>
                </form>
              </div>
            </td>
          </tr>
        <% } %>
      </tbody>
    </table>
  </div>
<% } %>

<%- include('footer') %>
