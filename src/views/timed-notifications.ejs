<%- include('header', { title: 'Timed Notifications', streamer: streamer }) %>

<style>
  /* ── Position grid ───────────────────────────────────────────── */
  .position-grid { display: grid; grid-template-columns: repeat(3, 28px); gap: 3px; }
  .position-btn {
    width: 28px; height: 28px; border-radius: 5px;
    border: 1px solid var(--border); background: var(--bg-elevated);
    cursor: pointer; transition: all 0.15s;
    display: flex; align-items: center; justify-content: center;
    font-size: 10px; color: var(--text-muted);
  }
  .position-btn:hover { border-color: var(--accent); background: rgba(145,70,255,0.1); color: var(--accent); }
  .position-btn.active { border-color: var(--accent); background: rgba(145,70,255,0.2); color: var(--accent); }

  /* ── Platform pills ──────────────────────────────────────────── */
  .platform-pill input { display: none; }
  .platform-pill .pill-inner {
    display: flex; align-items: center; gap: 6px;
    padding: 8px 14px; border-radius: 8px; font-size: 13px; font-weight: 600;
    border: 1px solid var(--border); background: var(--bg-base);
    color: var(--text-muted); cursor: pointer; transition: all 0.2s;
    user-select: none;
  }
  .platform-pill .pill-inner:hover { border-color: var(--pill-color, var(--accent)); opacity: 0.85; }
  .platform-pill input:checked + .pill-inner {
    border-color: var(--pill-color, var(--accent));
    background: rgba(var(--pill-rgb, 145,70,255), 0.1);
    color: var(--pill-color, var(--accent));
  }

  /* ── Overlay settings reveal ─────────────────────────────────── */
  .overlay-settings-wrap {
    overflow: hidden; max-height: 0;
    transition: max-height 0.35s cubic-bezier(0.4,0,0.2,1), opacity 0.3s ease;
    opacity: 0;
  }
  .overlay-settings-wrap.visible { max-height: 500px; opacity: 1; }
  .overlay-settings-inner {
    margin-top: 16px; padding: 20px; background: var(--bg-elevated);
    border-radius: 10px; border: 1px solid var(--border);
  }

  /* ── Color picker with hex ───────────────────────────────────── */
  .color-row { display: flex; align-items: center; gap: 8px; }
  .color-row input[type=color] {
    width: 36px; height: 36px; padding: 2px; border-radius: 6px;
    border: 1px solid var(--border); background: var(--bg-base);
    cursor: pointer; flex-shrink: 0;
  }
  .color-hex {
    font-family: var(--font-display); font-size: 12px; font-weight: 600;
    color: var(--text-secondary); letter-spacing: 0.05em;
    background: var(--bg-base); border: 1px solid var(--border);
    border-radius: 6px; padding: 7px 10px; width: 80px;
  }

  /* ── Toggle pill (enable/disable) ───────────────────────────── */
  .toggle-pill { position: relative; display: inline-block; width: 44px; height: 24px; flex-shrink: 0; }
  .toggle-pill input { opacity: 0; width: 0; height: 0; }
  .toggle-pill-slider { position: absolute; cursor: pointer; inset: 0; background: var(--border); border-radius: 24px; transition: 0.2s; }
  .toggle-pill-slider:before { position: absolute; content: ''; height: 18px; width: 18px; left: 3px; bottom: 3px; background: white; border-radius: 50%; transition: 0.2s; }
  .toggle-pill input:checked + .toggle-pill-slider { background: var(--success); }
  .toggle-pill input:checked + .toggle-pill-slider:before { transform: translateX(20px); }

  /* ── Notification cards ──────────────────────────────────────── */
  .notif-card {
    background: var(--bg-surface); border: 1px solid var(--border);
    border-radius: var(--radius); margin-bottom: 14px;
    transition: border-color 0.2s;
    overflow: hidden;
  }
  .notif-card:hover { border-color: rgba(145,70,255,0.3); }
  .notif-card-body { padding: 20px 20px 16px; }
  .notif-card-header {
    display: flex; align-items: center; gap: 12px;
    margin-bottom: 12px;
  }
  .notif-card-meta { flex: 1; min-width: 0; }
  .notif-card-name { font-size: 15px; font-weight: 700; color: var(--text-primary); }
  .notif-card-interval {
    font-size: 12px; color: var(--text-muted);
    background: var(--bg-elevated); border: 1px solid var(--border);
    border-radius: 20px; padding: 2px 9px; font-weight: 600; white-space: nowrap;
  }
  .notif-card-message {
    font-size: 13px; color: var(--text-secondary); line-height: 1.5;
    margin-bottom: 12px;
    overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
  }
  .notif-card-badges { display: flex; gap: 6px; flex-wrap: wrap; }
  .badge-twitch { background: rgba(145,70,255,0.15); color: #9146ff; border: 1px solid rgba(145,70,255,0.3); padding: 3px 9px; border-radius: 20px; font-size: 11px; font-weight: 600; }
  .badge-youtube { background: rgba(255,0,0,0.12); color: #ff4444; border: 1px solid rgba(255,0,0,0.25); padding: 3px 9px; border-radius: 20px; font-size: 11px; font-weight: 600; }
  .badge-overlay { background: rgba(247,144,9,0.12); color: #f79009; border: 1px solid rgba(247,144,9,0.25); padding: 3px 9px; border-radius: 20px; font-size: 11px; font-weight: 600; }

  /* ── Card action bar ─────────────────────────────────────────── */
  .notif-card-footer {
    border-top: 1px solid var(--border);
    padding: 12px 20px;
    display: flex; align-items: center; gap: 8px;
    background: var(--bg-elevated);
  }
  .notif-card-footer .btn { font-size: 12px; padding: 6px 13px; }
  .notif-card-footer .spacer { flex: 1; }

  /* ── Inline edit ─────────────────────────────────────────────── */
  .inline-edit-wrap {
    overflow: hidden; max-height: 0;
    transition: max-height 0.4s cubic-bezier(0.4,0,0.2,1), opacity 0.3s ease;
    opacity: 0;
  }
  .inline-edit-wrap.visible { max-height: 1200px; opacity: 1; }
  .inline-edit-inner {
    border-top: 2px solid var(--accent);
    padding: 24px 20px;
    background: var(--bg-surface);
  }
  .inline-edit-inner h4 {
    font-size: 13px; font-weight: 700; text-transform: uppercase;
    letter-spacing: 0.07em; color: var(--accent); margin-bottom: 20px;
  }

  /* ── Section label ───────────────────────────────────────────── */
  .section-label {
    font-size: 11px; font-weight: 700; text-transform: uppercase;
    letter-spacing: 0.07em; color: var(--text-muted);
    margin-bottom: 8px;
  }

  /* ── Empty state ─────────────────────────────────────────────── */
  .empty-state {
    text-align: center; padding: 56px 24px;
    background: var(--bg-surface); border: 1px dashed var(--border);
    border-radius: var(--radius);
  }
  .empty-state-icon {
    width: 56px; height: 56px; margin: 0 auto 16px;
    background: var(--bg-elevated); border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
  }
  .empty-state h4 { font-size: 16px; font-weight: 700; margin-bottom: 6px; }
  .empty-state p { font-size: 14px; color: var(--text-muted); }

  /* ── Create button ───────────────────────────────────────────── */
  .btn-create {
    width: 100%; padding: 12px; font-size: 14px; font-weight: 700;
    margin-top: 4px;
  }
</style>

<a href="/dashboard" style="color: var(--text-secondary); font-size: 13px; font-family: var(--font-display); font-weight: 500; display: inline-flex; align-items: center; gap: 6px;">
  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
  Back to Dashboard
</a>
<h2 style="margin: 16px 0 6px; font-size: 24px; font-weight: 700;" class="animate-in">Timed Notifications</h2>
<p style="color: var(--text-secondary); font-size: 14px; margin-bottom: 28px;">Schedule automatic messages for chat and overlay banners.</p>

<!-- ── Create Notification Card ──────────────────────────────────── -->
<div class="card animate-in" style="margin-bottom: 28px;">
  <h3 style="margin-bottom: 22px; font-size: 16px; font-weight: 700; display: flex; align-items: center; gap: 8px;">
    <span style="width: 30px; height: 30px; background: rgba(145,70,255,0.12); border-radius: 8px; display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
      <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#9146ff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
    </span>
    Create Notification
  </h3>

  <form method="POST" action="/dashboard/timed-notifications" id="add-form">

    <!-- Name + Interval -->
    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin-bottom: 16px;">
      <div>
        <label class="form-label">Name</label>
        <input type="text" name="name" class="form-control" placeholder="e.g. Discord Reminder" required>
      </div>
      <div>
        <label class="form-label">Interval</label>
        <select name="interval_minutes" class="form-control">
          <option value="5">Every 5 minutes</option>
          <option value="10">Every 10 minutes</option>
          <option value="15" selected>Every 15 minutes</option>
          <option value="20">Every 20 minutes</option>
          <option value="30">Every 30 minutes</option>
          <option value="45">Every 45 minutes</option>
          <option value="60">Every 60 minutes</option>
        </select>
      </div>
    </div>

    <!-- Chat Message -->
    <div style="margin-bottom: 16px;">
      <label class="form-label">Chat Message</label>
      <textarea name="message" class="form-control" rows="2" placeholder="Message to send in chat..." required></textarea>
    </div>

    <!-- Overlay Text -->
    <div style="margin-bottom: 20px;">
      <label class="form-label">
        Overlay Text
        <span style="color: var(--text-muted); font-weight: 400; font-size: 12px; margin-left: 4px;">optional — leave blank to use chat message</span>
      </label>
      <textarea name="overlay_text" class="form-control" rows="2" placeholder="Text shown on the stream overlay (optional)…"></textarea>
    </div>

    <!-- Platform pills -->
    <div style="margin-bottom: 20px;">
      <div class="section-label">Send To</div>
      <div style="display: flex; gap: 8px; flex-wrap: wrap;">

        <label class="platform-pill" style="--pill-color: #9146ff; --pill-rgb: 145,70,255;">
          <input type="checkbox" name="send_to_twitch" value="1" checked>
          <span class="pill-inner">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor"><path d="M2.149 0L.537 4.119v16.836h5.731V24l4.119-3.045H14.7L21.435 14.2V0H2.149zm17.09 13.462l-3.284 3.284H11.7l-2.985 2.985v-2.985H4.238V2.238h14.999v11.224z"/><path d="M18.418 5.97h-2.238v6.716h2.238V5.97zm-5.97 0h-2.239v6.716h2.239V5.97z"/></svg>
            Twitch Chat
          </span>
        </label>

        <label class="platform-pill" style="--pill-color: #ff4444; --pill-rgb: 255,68,68;">
          <input type="checkbox" name="send_to_youtube" value="1">
          <span class="pill-inner">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
            YouTube Chat
          </span>
        </label>

        <label class="platform-pill" style="--pill-color: #f79009; --pill-rgb: 247,144,9;">
          <input type="checkbox" name="show_overlay" value="1" class="toggle-overlay-add">
          <span class="pill-inner">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
            Show Overlay
          </span>
        </label>

      </div>
    </div>

    <!-- Overlay Settings (add form) -->
    <div class="overlay-settings-wrap" id="overlay-settings-add">
      <div class="overlay-settings-inner">
        <div class="section-label" style="margin-bottom: 16px;">Overlay Settings</div>
        <div style="display: grid; grid-template-columns: auto 120px 1fr 1fr; gap: 20px; align-items: start;">

          <!-- Position grid -->
          <div>
            <div class="section-label">Position</div>
            <div class="position-grid" id="pos-grid-add">
              <button type="button" class="position-btn" data-pos="top-left" title="Top Left">↖</button>
              <button type="button" class="position-btn" data-pos="top-center" title="Top Center">↑</button>
              <button type="button" class="position-btn" data-pos="top-right" title="Top Right">↗</button>
              <button type="button" class="position-btn" data-pos="mid-left" title="Middle Left">←</button>
              <button type="button" class="position-btn" data-pos="mid-center" title="Center">·</button>
              <button type="button" class="position-btn" data-pos="mid-right" title="Middle Right">→</button>
              <button type="button" class="position-btn active" data-pos="bot-left" title="Bottom Left">↙</button>
              <button type="button" class="position-btn" data-pos="bot-center" title="Bottom Center">↓</button>
              <button type="button" class="position-btn" data-pos="bot-right" title="Bottom Right">↘</button>
            </div>
            <input type="hidden" name="overlay_position" value="bot-left" id="pos-input-add">
          </div>

          <!-- Duration -->
          <div>
            <div class="section-label">Duration (sec)</div>
            <input type="number" name="overlay_duration" class="form-control" value="8" min="2" max="30">
          </div>

          <!-- BG Color -->
          <div>
            <div class="section-label">Background</div>
            <div class="color-row">
              <input type="color" name="overlay_bg_color" value="#1a1a2e" id="add-bg-color" oninput="document.getElementById('add-bg-hex').value=this.value.toUpperCase()">
              <input type="text" class="color-hex" id="add-bg-hex" value="#1A1A2E" maxlength="7" oninput="syncColorPicker('add-bg-color',this.value)">
            </div>
          </div>

          <!-- Text Color -->
          <div>
            <div class="section-label">Text Color</div>
            <div class="color-row">
              <input type="color" name="overlay_text_color" value="#ffffff" id="add-text-color" oninput="document.getElementById('add-text-hex').value=this.value.toUpperCase()">
              <input type="text" class="color-hex" id="add-text-hex" value="#FFFFFF" maxlength="7" oninput="syncColorPicker('add-text-color',this.value)">
            </div>
          </div>

        </div>
      </div>
    </div>

    <!-- Submit -->
    <div style="margin-top: 20px;">
      <button type="submit" class="btn btn-primary btn-create">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="vertical-align: middle; margin-right: 6px;"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
        Create Notification
      </button>
    </div>

  </form>
</div>

<!-- ── Notifications List ─────────────────────────────────────────── -->
<% if (notifications.length === 0) { %>

  <div class="empty-state animate-in">
    <div class="empty-state-icon">
      <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="var(--text-muted)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
    </div>
    <h4>No notifications yet</h4>
    <p>Create your first timed notification above to start scheduling automatic messages.</p>
  </div>

<% } else { %>

  <div class="animate-in">
    <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 14px;">
      <h3 style="font-size: 14px; font-weight: 700; color: var(--text-secondary); text-transform: uppercase; letter-spacing: 0.06em;">
        Scheduled Notifications
        <span style="font-size: 12px; font-weight: 600; background: var(--bg-elevated); border: 1px solid var(--border); border-radius: 20px; padding: 1px 8px; margin-left: 6px; color: var(--text-muted); letter-spacing: 0;"><%= notifications.length %></span>
      </h3>
    </div>

    <% notifications.forEach(function(n) { %>
    <div class="notif-card">
      <div class="notif-card-body">

        <!-- Header row -->
        <div class="notif-card-header">
          <!-- Enable/disable toggle -->
          <form method="POST" action="/dashboard/timed-notifications/<%= n.id %>/update" style="display: contents;">
            <input type="hidden" name="name" value="<%= n.name %>">
            <input type="hidden" name="message" value="<%= n.message %>">
            <input type="hidden" name="overlay_text" value="<%= n.overlay_text || '' %>">
            <input type="hidden" name="interval_minutes" value="<%= n.interval_minutes %>">
            <input type="hidden" name="send_to_twitch" value="<%= n.send_to_twitch ? '1' : '' %>">
            <input type="hidden" name="send_to_youtube" value="<%= n.send_to_youtube ? '1' : '' %>">
            <input type="hidden" name="show_overlay" value="<%= n.show_overlay ? '1' : '' %>">
            <input type="hidden" name="overlay_position" value="<%= n.overlay_position %>">
            <input type="hidden" name="overlay_duration" value="<%= n.overlay_duration %>">
            <input type="hidden" name="overlay_bg_color" value="<%= n.overlay_bg_color %>">
            <input type="hidden" name="overlay_text_color" value="<%= n.overlay_text_color %>">
            <input type="hidden" name="enabled" value="<%= n.enabled ? '' : '1' %>">
            <label class="toggle-pill" title="<%= n.enabled ? 'Enabled — click to disable' : 'Disabled — click to enable' %>">
              <input type="checkbox" <%= n.enabled ? 'checked' : '' %> onchange="this.form.submit()">
              <span class="toggle-pill-slider"></span>
            </label>
          </form>

          <!-- Name + interval -->
          <div class="notif-card-meta">
            <div style="display: flex; align-items: center; gap: 10px; flex-wrap: wrap;">
              <span class="notif-card-name"><%= n.name %></span>
              <span class="notif-card-interval">Every <%= n.interval_minutes %> min</span>
            </div>
          </div>
        </div>

        <!-- Message -->
        <div class="notif-card-message">
          <%= n.message.length > 100 ? n.message.substring(0, 100) + '…' : n.message %>
        </div>

        <!-- Platform badges -->
        <div class="notif-card-badges">
          <% if (n.send_to_twitch) { %>
            <span class="badge-twitch">
              <svg width="10" height="10" viewBox="0 0 24 24" fill="currentColor" style="vertical-align: middle; margin-right: 3px;"><path d="M2.149 0L.537 4.119v16.836h5.731V24l4.119-3.045H14.7L21.435 14.2V0H2.149zm17.09 13.462l-3.284 3.284H11.7l-2.985 2.985v-2.985H4.238V2.238h14.999v11.224z"/></svg>
              Twitch
            </span>
          <% } %>
          <% if (n.send_to_youtube) { %>
            <span class="badge-youtube">
              <svg width="10" height="10" viewBox="0 0 24 24" fill="currentColor" style="vertical-align: middle; margin-right: 3px;"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
              YouTube
            </span>
          <% } %>
          <% if (n.show_overlay) { %>
            <span class="badge-overlay">
              <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="vertical-align: middle; margin-right: 3px;"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
              Overlay
            </span>
          <% } %>
        </div>

      </div>

      <!-- Action bar -->
      <div class="notif-card-footer">
        <button type="button" class="btn btn-secondary" onclick="testNotification(<%= n.id %>, this)">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="vertical-align: middle; margin-right: 4px;"><polygon points="5 3 19 12 5 21 5 3"/></svg>
          Test
        </button>
        <button type="button" class="btn btn-secondary" onclick="toggleEdit(<%= n.id %>)">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="vertical-align: middle; margin-right: 4px;"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
          Edit
        </button>
        <div class="spacer"></div>
        <form method="POST" action="/dashboard/timed-notifications/<%= n.id %>/delete" style="display: inline;" onsubmit="return confirm('Delete &quot;<%= n.name %>&quot;?')">
          <button type="submit" class="btn btn-danger">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="vertical-align: middle; margin-right: 4px;"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/><path d="M10 11v6"/><path d="M14 11v6"/><path d="M9 6V4a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2"/></svg>
            Delete
          </button>
        </form>
      </div>

      <!-- Inline Edit Form -->
      <div class="inline-edit-wrap" id="edit-<%= n.id %>">
        <div class="inline-edit-inner">
          <h4>Edit Notification</h4>
          <form method="POST" action="/dashboard/timed-notifications/<%= n.id %>/update">

            <!-- Name + Interval -->
            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin-bottom: 16px;">
              <div>
                <label class="form-label">Name</label>
                <input type="text" name="name" class="form-control" value="<%= n.name %>" required>
              </div>
              <div>
                <label class="form-label">Interval</label>
                <select name="interval_minutes" class="form-control">
                  <option value="5" <%= n.interval_minutes == 5 ? 'selected' : '' %>>Every 5 minutes</option>
                  <option value="10" <%= n.interval_minutes == 10 ? 'selected' : '' %>>Every 10 minutes</option>
                  <option value="15" <%= n.interval_minutes == 15 ? 'selected' : '' %>>Every 15 minutes</option>
                  <option value="20" <%= n.interval_minutes == 20 ? 'selected' : '' %>>Every 20 minutes</option>
                  <option value="30" <%= n.interval_minutes == 30 ? 'selected' : '' %>>Every 30 minutes</option>
                  <option value="45" <%= n.interval_minutes == 45 ? 'selected' : '' %>>Every 45 minutes</option>
                  <option value="60" <%= n.interval_minutes == 60 ? 'selected' : '' %>>Every 60 minutes</option>
                </select>
              </div>
            </div>

            <!-- Chat Message -->
            <div style="margin-bottom: 16px;">
              <label class="form-label">Chat Message</label>
              <textarea name="message" class="form-control" rows="2" required><%= n.message %></textarea>
            </div>

            <!-- Overlay Text -->
            <div style="margin-bottom: 20px;">
              <label class="form-label">
                Overlay Text
                <span style="color: var(--text-muted); font-weight: 400; font-size: 12px; margin-left: 4px;">optional</span>
              </label>
              <textarea name="overlay_text" class="form-control" rows="2"><%= n.overlay_text || '' %></textarea>
            </div>

            <!-- Platform pills -->
            <div style="margin-bottom: 20px;">
              <div class="section-label">Send To</div>
              <div style="display: flex; gap: 8px; flex-wrap: wrap;">

                <label class="platform-pill" style="--pill-color: #9146ff; --pill-rgb: 145,70,255;">
                  <input type="checkbox" name="send_to_twitch" value="1" <%= n.send_to_twitch ? 'checked' : '' %>>
                  <span class="pill-inner">
                    <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor"><path d="M2.149 0L.537 4.119v16.836h5.731V24l4.119-3.045H14.7L21.435 14.2V0H2.149zm17.09 13.462l-3.284 3.284H11.7l-2.985 2.985v-2.985H4.238V2.238h14.999v11.224z"/><path d="M18.418 5.97h-2.238v6.716h2.238V5.97zm-5.97 0h-2.239v6.716h2.239V5.97z"/></svg>
                    Twitch Chat
                  </span>
                </label>

                <label class="platform-pill" style="--pill-color: #ff4444; --pill-rgb: 255,68,68;">
                  <input type="checkbox" name="send_to_youtube" value="1" <%= n.send_to_youtube ? 'checked' : '' %>>
                  <span class="pill-inner">
                    <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
                    YouTube Chat
                  </span>
                </label>

                <label class="platform-pill" style="--pill-color: #f79009; --pill-rgb: 247,144,9;">
                  <input type="checkbox" name="show_overlay" value="1" <%= n.show_overlay ? 'checked' : '' %> class="toggle-overlay-edit" data-id="<%= n.id %>">
                  <span class="pill-inner">
                    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
                    Show Overlay
                  </span>
                </label>

              </div>
            </div>

            <!-- Overlay Settings (edit form) -->
            <div class="overlay-settings-wrap" id="overlay-settings-edit-<%= n.id %>" <%= n.show_overlay ? 'style="max-height:500px;opacity:1;"' : '' %>>
              <div class="overlay-settings-inner">
                <div class="section-label" style="margin-bottom: 16px;">Overlay Settings</div>
                <div style="display: grid; grid-template-columns: auto 120px 1fr 1fr; gap: 20px; align-items: start;">

                  <!-- Position grid -->
                  <div>
                    <div class="section-label">Position</div>
                    <div class="position-grid" id="pos-grid-edit-<%= n.id %>">
                      <button type="button" class="position-btn <%= n.overlay_position === 'top-left'    ? 'active' : '' %>" data-pos="top-left"    title="Top Left">↖</button>
                      <button type="button" class="position-btn <%= n.overlay_position === 'top-center'  ? 'active' : '' %>" data-pos="top-center"  title="Top Center">↑</button>
                      <button type="button" class="position-btn <%= n.overlay_position === 'top-right'   ? 'active' : '' %>" data-pos="top-right"   title="Top Right">↗</button>
                      <button type="button" class="position-btn <%= n.overlay_position === 'mid-left'    ? 'active' : '' %>" data-pos="mid-left"    title="Middle Left">←</button>
                      <button type="button" class="position-btn <%= n.overlay_position === 'mid-center'  ? 'active' : '' %>" data-pos="mid-center"  title="Center">·</button>
                      <button type="button" class="position-btn <%= n.overlay_position === 'mid-right'   ? 'active' : '' %>" data-pos="mid-right"   title="Middle Right">→</button>
                      <button type="button" class="position-btn <%= n.overlay_position === 'bot-left'    ? 'active' : '' %>" data-pos="bot-left"    title="Bottom Left">↙</button>
                      <button type="button" class="position-btn <%= n.overlay_position === 'bot-center'  ? 'active' : '' %>" data-pos="bot-center"  title="Bottom Center">↓</button>
                      <button type="button" class="position-btn <%= n.overlay_position === 'bot-right'   ? 'active' : '' %>" data-pos="bot-right"   title="Bottom Right">↘</button>
                    </div>
                    <input type="hidden" name="overlay_position" value="<%= n.overlay_position %>" id="pos-input-edit-<%= n.id %>">
                  </div>

                  <!-- Duration -->
                  <div>
                    <div class="section-label">Duration (sec)</div>
                    <input type="number" name="overlay_duration" class="form-control" value="<%= n.overlay_duration %>" min="2" max="30">
                  </div>

                  <!-- BG Color -->
                  <div>
                    <div class="section-label">Background</div>
                    <div class="color-row">
                      <input type="color" name="overlay_bg_color" value="<%= n.overlay_bg_color %>" id="edit-bg-color-<%= n.id %>" oninput="document.getElementById('edit-bg-hex-<%= n.id %>').value=this.value.toUpperCase()">
                      <input type="text" class="color-hex" id="edit-bg-hex-<%= n.id %>" value="<%= n.overlay_bg_color.toUpperCase() %>" maxlength="7" oninput="syncColorPicker('edit-bg-color-<%= n.id %>',this.value)">
                    </div>
                  </div>

                  <!-- Text Color -->
                  <div>
                    <div class="section-label">Text Color</div>
                    <div class="color-row">
                      <input type="color" name="overlay_text_color" value="<%= n.overlay_text_color %>" id="edit-text-color-<%= n.id %>" oninput="document.getElementById('edit-text-hex-<%= n.id %>').value=this.value.toUpperCase()">
                      <input type="text" class="color-hex" id="edit-text-hex-<%= n.id %>" value="<%= n.overlay_text_color.toUpperCase() %>" maxlength="7" oninput="syncColorPicker('edit-text-color-<%= n.id %>',this.value)">
                    </div>
                  </div>

                </div>
              </div>
            </div>

            <input type="hidden" name="enabled" value="<%= n.enabled ? '1' : '' %>">

            <div style="margin-top: 20px; display: flex; gap: 8px;">
              <button type="submit" class="btn btn-primary" style="padding: 9px 20px;">Save Changes</button>
              <button type="button" class="btn btn-secondary" style="padding: 9px 20px;" onclick="toggleEdit(<%= n.id %>)">Cancel</button>
            </div>

          </form>
        </div>
      </div>
    </div>
    <% }); %>
  </div>

<% } %>

<script>
function toggleEdit(id) {
  const el = document.getElementById('edit-' + id);
  el.classList.toggle('visible');
}

function testNotification(id, btn) {
  const originalText = btn.innerHTML;
  btn.disabled = true;
  btn.innerHTML = 'Firing…';
  fetch('/dashboard/timed-notifications/' + id + '/test', { method: 'POST' })
    .then(r => r.json())
    .then(data => {
      btn.innerHTML = data.ok ? 'Fired!' : 'Error';
      setTimeout(() => { btn.innerHTML = originalText; btn.disabled = false; }, 2000);
    })
    .catch(() => {
      btn.innerHTML = 'Error';
      setTimeout(() => { btn.innerHTML = originalText; btn.disabled = false; }, 2000);
    });
}

// Position grid logic
function initPositionGrid(gridId, inputId) {
  const grid = document.getElementById(gridId);
  if (!grid) return;
  const input = document.getElementById(inputId);
  grid.querySelectorAll('.position-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      grid.querySelectorAll('.position-btn').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      if (input) input.value = btn.dataset.pos;
    });
  });
}

// Color picker ↔ hex text sync
function syncColorPicker(pickerId, hexVal) {
  if (/^#[0-9a-fA-F]{6}$/.test(hexVal)) {
    const picker = document.getElementById(pickerId);
    if (picker) picker.value = hexVal;
  }
}

// Add form
initPositionGrid('pos-grid-add', 'pos-input-add');

// Edit form position grids
<% notifications.forEach(function(n) { %>
initPositionGrid('pos-grid-edit-<%= n.id %>', 'pos-input-edit-<%= n.id %>');
<% }); %>

// Overlay toggle — add form
document.querySelectorAll('.toggle-overlay-add').forEach(cb => {
  cb.addEventListener('change', () => {
    const settings = document.getElementById('overlay-settings-add');
    settings.classList.toggle('visible', cb.checked);
  });
});

// Overlay toggle — edit forms
document.querySelectorAll('.toggle-overlay-edit').forEach(cb => {
  cb.addEventListener('change', () => {
    const id = cb.dataset.id;
    const settings = document.getElementById('overlay-settings-edit-' + id);
    if (settings) settings.classList.toggle('visible', cb.checked);
  });
});
</script>

<%- include('footer') %>
